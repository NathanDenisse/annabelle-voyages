rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Lecture publique pour les collections du site vitrine
    match /content/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /socials/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /portfolio/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /partnerships/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Messages : écriture publique (formulaire contact), lecture/gestion admin uniquement
    match /messages/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Hero media
    match /hero/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /testimonials/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
